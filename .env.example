# Copy this file to .env and fill in your values.

# Dashboard
UI_HOST=0.0.0.0
UI_PORT=8000
AGENT_HOST=0.0.0.0
AGENT_PORT=8081

# Gemini 3.1 Live
GOOGLE_API_KEY=your_gemini_api_key
VOICE_MODE=gemini_live
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
GEMINI_LIVE_VOICE=Puck
GEMINI_LIVE_TEMPERATURE=0.8
GEMINI_LIVE_LANGUAGE=

# LiveKit
LIVEKIT_URL=wss://your-livekit-url
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-key

# Optional WhatsApp automations
WHATSAPP_ENABLED=false
WHATSAPP_PROVIDER=vobiz
VOBIZ_AUTH_ID=
VOBIZ_AUTH_TOKEN=
VOBIZ_WHATSAPP_CHANNEL_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
WHATSAPP_SERVICE_URL=http://127.0.0.1:3010
WHATSAPP_SESSION_NAME=primary

# Optional
SENTRY_DSN=
